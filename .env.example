# -----------------------------------------------------------------------------
# SimuFlux Design Lab — Environment Variables
# Copy this file to '.env.local' and fill in ALL values before running the app.
# NEVER commit '.env.local' to git — it contains secrets!
# -----------------------------------------------------------------------------

# ── App URL ──────────────────────────────────────────────────────────────────
# The full public URL of this site (used by NextAuth for redirects & callbacks)
NEXTAUTH_URL=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get your connection string from MongoDB Atlas (free M0 tier is fine)
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/simufluxlab?retryWrites=true&w=majority

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# ── Resend (Transactional Email) ──────────────────────────────────────────────
# Sign up at https://resend.com and create an API key under your verified domain
RESEND_API_KEY=re_your_resend_api_key_here

# The email address to send system emails FROM.
# TODO: switch RESEND_FROM_EMAIL to the client's verified domain email once domain is set up
# e.g. RESEND_FROM_EMAIL="SimuFlux System <system@simuflux.com>"
# Until the domain is verified in your Resend dashboard, use onboarding@resend.dev
# (test-mode sender — only delivers to your own Resend-verified account email)
RESEND_FROM_EMAIL=SimuFlux Admin <onboarding@resend.dev>

# The email address to send admin notifications TO (inquiries, registrations, etc.)
# During testing use your own Gmail; in production use the client's verified email
ADMIN_EMAIL=your_admin_email@example.com

# ── Google Sheets Integration ─────────────────────────────────────────────────
# 1. Create a Google Cloud project and enable the Google Sheets API
# 2. Create a Service Account, download the JSON key file
# 3. Share your target Google Sheet as Editor with the service account email
# 4. Copy the values from the downloaded JSON below

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the private key exactly as-is from the JSON file (keep the \\n literals)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# The ID from the Google Sheet URL: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
# TODO: Update the Sheet's header row (Row 1) to match exactly:
# Name | CNIC | Email | Phone | Highest Qualification | Currently Pursuing | University | City | Reason | Course | Date | Screenshot Link
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────────────────────
# Register a site at https://dash.cloudflare.com → Turnstile
# Use "Managed" mode for the best balance of UX and bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ── Admin WhatsApp Business Number ────────────────────────────────────────────
# Used by the Inquiry modal to build wa.me prefilled message links
# Format: international digits ONLY — no +, no 00, no spaces
# Example: 923001234567  (for +92 300 1234567)
# TODO: Replace with the real WhatsApp Business number in international format without + or 00
ADMIN_WHATSAPP_PHONE=923463517689
NEXT_PUBLIC_ADMIN_WHATSAPP_PHONE=923463517689

# ── Cloudinary (Image Uploads) ────────────────────────────────────────────────
# Required for production image uploads (service/course images + registration payment screenshots).
# TODO: Sign up free at https://cloudinary.com — get these three values from your Cloudinary dashboard:
#   Dashboard → API Keys → Create API Key
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ── Upstash Redis (Rate Limiting) ─────────────────────────────────────────────
# Required for API rate limiting. Sign up free at https://upstash.com
# Setup instructions:
# 1. Go to https://upstash.com and sign up (free tier available)
# 2. Create a new Redis database
# 3. Go to Database Details → REST API
# 4. Copy the REST URL and REST Token
# 5. Paste them below
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token_here

